DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
LOCAL_LLM_PROVIDER=mock_local
LOCAL_LLM_MODEL=mock-local-intent
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_TIMEOUT=8
LOCAL_LLM_MAX_CONTEXT_TOKENS=7500
LOCAL_LLM_GENERATION_BUFFER_TOKENS=500
LOCAL_LLM_MAX_OUTPUT_TOKENS=64
# To simulate an in-vehicle small LLM with DeepSeek, use:
# LOCAL_LLM_PROVIDER=edge_deepseek_sim
# LOCAL_LLM_MODEL=deepseek-v4-flash
# LOCAL_LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
ENABLE_LLM_INTENT_FALLBACK=0
ENABLE_LOCAL_LLM_SAFETY_EXPLAIN=0
ENABLE_LOCAL_LLM_CONTROL_EXPLAIN=0
ENABLE_LANGGRAPH=1
BAIDU_MAP_AK=your_baidu_map_ak
AMAP_API_KEY=your_amap_web_service_key
OPENCHARGEMAP_API_KEY=your_openchargemap_key
